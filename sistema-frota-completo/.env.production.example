# ============================================
# CONFIGURAÇÃO DE PRODUÇÃO - SISTEMA DE FROTA
# ============================================
# Copie este arquivo para .env.production e preencha com seus valores reais

# ============================================
# BANCO DE DADOS - LOGÍSTICA (Banco Principal)
# ============================================
# Substitua pelos dados reais do seu banco PostgreSQL
DATABASE_URL_LOGISTICA=postgresql://postgres:senha@192.168.1.171:5432/logistica

# ============================================
# BANCO DE DADOS - ERP (Somente Leitura)
# ============================================
# Substitua pelos dados reais do seu banco ERP
DATABASE_URL_ERP=postgresql://postgres:senha@192.168.1.17:5432/salutem

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# AUTENTICAÇÃO OAUTH (Manus)
# ============================================
# Para usar OAuth em produção, configure estas variáveis:
VITE_APP_ID=seu-app-id-aqui
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://app.manus.im
JWT_SECRET=sua-chave-secreta-super-segura-aqui

# ============================================
# INFORMAÇÕES DO PROPRIETÁRIO
# ============================================
OWNER_NAME=Sistema de Logística
OWNER_OPEN_ID=seu-open-id-aqui

# ============================================
# INTEGRAÇÕES EXTERNAS
# ============================================
# Google Maps
GOOGLE_MAPS_API_KEY=sua-chave-google-maps

# WhatsApp
WHATSAPP_API_KEY=sua-chave-whatsapp
WHATSAPP_API_URL=https://api.whatsapp.com

# ============================================
# CONFIGURAÇÕES DO SISTEMA
# ============================================
GPS_TRACKING_INTERVAL_SECONDS=60
ROUTE_DEVIATION_TOLERANCE_METERS=100

# ============================================
# MANUS APIS (Opcional)
# ============================================
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ============================================
# ANALYTICS (Opcional)
# ============================================
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ============================================
# APP INFO
# ============================================
VITE_APP_TITLE=Sistema de Logística
VITE_APP_LOGO=
VITE_APP_ID=seu-app-id-aqui

# ============================================
# BANCO DE DADOS ERP
# ============================================
ERP_DB_PASSWORD=postgres
